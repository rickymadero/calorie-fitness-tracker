{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Evolve: Start Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "evolve"
      },
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(✓ Ready|Ready in|Local:)"
        }
      }
    },
    {
      "label": "Evolve: Show Mobile Preview",
      "type": "shell",
      "command": "echo ${input:evolveOpenMobilePreview}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "echo": false,
        "close": true,
        "panel": "shared"
      }
    },
    {
      "label": "Evolve: Mobile Preview",
      "dependsOn": [
        "Evolve: Start Dev Server",
        "Evolve: Show Mobile Preview"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Evolve: Show Full Browser",
      "type": "shell",
      "command": "echo ${input:evolveOpenFullPreview}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "echo": false,
        "close": true,
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "evolveOpenMobilePreview",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:3000/dev/preview"]
    },
    {
      "id": "evolveOpenFullPreview",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:3000"]
    }
  ]
}
